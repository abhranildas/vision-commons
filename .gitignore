# Shared data store (vislab-common/data). Keep the small calibration .mat files and
# the texture sheets in git; ignore only the big stuff -- the ~19 GB natural-image
# set and the ~3.7 GB derived CDFs (obtained separately / synced via OneDrive).
# (GitHub rejects files >100 MB.) Default to ignoring everything, then re-include:
/data/*
!/data/*.mat
!/data/textures/
# ...except the ~3.7 GB derived CDFs, which is too large for git:
/data/nat_im_cdfs.mat

# Unignore a small subset of the natural images (first 4 of each set) for the demo
!/data/CPS natural images/
/data/CPS natural images/*
!/data/CPS natural images/Set9_16_1.png
!/data/CPS natural images/Set9_16_2.png
!/data/CPS natural images/Set9_16_3.png
!/data/CPS natural images/Set9_16_4.png
